{
  "name": "animelearn",
  "version": "1.0.0",
  "description": "AnimeLearn Project",
  "main": "index.js",
  "scripts": {
    "start:frontend": "npm run dev --prefix frontend",
    "start:backend": "npm run dev --prefix backend",
    "start:ai": "cd backend/src/scripts && py server_AI.py",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\" \"npm run start:ai\"",
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "cloudinary": "^2.9.0",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0"
  }
}
